function getRetHtml(val) {
  if (val > 0) return `<span class="val-pos">+${val.toFixed(2)}%</span>`;
  if (val < 0) return `<span class="val-neg">${val.toFixed(2)}%</span>`;
  return `<span>${val.toFixed(2)}%</span>`;
}

